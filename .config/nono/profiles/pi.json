{
  "meta": {
    "name": "pi",
    "version": "1.0.0"
  },
  "filesystem": {
    "unix_socket": [
      "~/.config/herdr/herdr-client.sock",
      "~/.config/herdr/herdr.sock"
    ],
    "write": [
      "./",
      "~/.pi",
      "~/.config/herdr"
    ],
    "read": [
      "./",
      "/Users/pichurri/.gitconfig",
      "/opt/homebrew/bin/",
      "~/.config/herdr",
      "~/.config/nono/profiles/pi.json",
      "~/.local/share/uv",
      "~/.pi",
      "~/dotfiles/.config/nono/profiles/pi.json",
      "~/dotfiles/.pi",
      "~/homebrew",
      "~/miniforge3",
    ]
  },
  "network": {
    "allow_port": [
      1234
    ],
    "allow_domain": [
      "openrouter.ai",
      "pi.dev",
      "af-cheap.openai.azure.com",
      "secops-ai-foundry.services.ai.azure.com"
    ]
  }
}