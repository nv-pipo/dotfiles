{
  "meta": {
    "name": "pi",
    "version": "1.0.0"
  },
  "filesystem": {
    "write": [
      "./",
      "~/.pi"
    ],
    "read": [
      "./",
      "~/.pi",
      "/opt/homebrew/bin/",
      "~/homebrew",
      "~/miniforge3",
      "~/.local/share/uv"
    ]
  },
  "network": {
    "allow_domain": [
      "openrouter.ai",
      "pi.dev"
    ]
  }
}